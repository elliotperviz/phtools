# TEMPLATE for phonchar
# remove the first two lines and the blank lines between blocks
1 1 1                   # 1 or 0, flag to specify the character to calculate
                        # eigenvalues, direction, displacement. If direction
                        # is enabled, the corresponding input block is expected
band.yaml POSCAR        # yaml file [POSCAR]: if yaml file is of kind qpoints.yaml
                        # the corresponding POSCAR geometry must be provided
1.0 0.0 0.0             # drift vector components
0.0 360.0 10            # starting angle, final angle, number of divisions;
                        # if starting angle = final angle, no scan is performed
2                       # number of atomic groups
3                       # number of atoms in group 1 (WSe2 layer)
1                       # label of the first atom in the group
3                       # ...
4                       # label of the last atom in the group
3                       # number of atoms in group 2 (MoSe layer)
2                       # label of the first atom in the group
5                       # ...
6                       # label of the last atom in the group
